{
  "name": "astro-starter",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "npx tinacms dev -c 'astro dev'",
    "host": "npx tinacms dev -c 'astro dev --host'",
    "start": "astro dev",
    "build": "NODE_ENV=production npx tinacms build --local --skip-cloud-checks -c 'astro build'",
    "preview": "npm run build -- --skip-cloud-checks && npx astro preview",
    "astro": "astro",
    "lint": "npx astro check && npx stylelint src/**/*.{css,scss,sass,astro} && npx prettier -c .",
    "cloudformation:package": "aws cloudformation package --template-file aws.template.yaml --s3-bucket cf-templates-m6s9n0rrcicj-us-east-1 --s3-prefix static-websites --output-template-file ./packaged.template.yaml",
    "cloudformation:deploy": "aws cloudformation deploy --template-file ./packaged.template.yaml --stack-name AstroStarter --capabilities CAPABILITY_IAM CAPABILITY_AUTO_EXPAND"
  },
  "dependencies": {
    "@11ty/eleventy-fetch": "^4.0.1",
    "@astrojs/react": "^5.0.3",
    "@dawaltconley/responsive-images": "^0.5.1",
    "@fortawesome/fontawesome-common-types": "^6.4.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/pro-regular-svg-icons": "^6.7.2",
    "@headlessui/react": "^2.2.10",
    "@iconify/types": "^2.0.0",
    "@microlink/mql": "^0.11.10",
    "@react-hook/resize-observer": "^2.0.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tinacms/cli": "^1.12.6",
    "@types/flat-cache": "^2.0.2",
    "@types/lodash": "^4.17.24",
    "@types/mime-types": "^2.1.4",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "astro": "^6.1.5",
    "astro-tina": "^0.1.3",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "cssnano": "^6.1.2",
    "hamburgers": "^1.2.1",
    "lodash": "^4.18.1",
    "mime-types": "^2.1.35",
    "postcss": "^8.5.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.99.0",
    "sass-parallax": "^0.6.1",
    "sass-tailwind-functions": "^2.0.0",
    "sharp": "^0.33.5",
    "slugify": "^1.6.9",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.19",
    "tinacms": "^2.8.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@dawaltconley/cfn-static-website": "^3.2.0",
    "@dawaltconley/contact-api": "^0.2.4",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "stylelint": "^15.11.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-scss": "^13.1.0"
  }
}
